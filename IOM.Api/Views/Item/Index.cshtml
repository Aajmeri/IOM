@model IEnumerable<IOM.Api.Resources.ItemResource>
@{
    ViewBag.Title = "Items";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content">
    <div class="container-fluid">
        <div class="row">
         <div class="col-lg-1 col-md-6 col-sm-6">
             </div>

            <div class="col-lg-10 col-md-6 col-sm-6">
            @if(Model.Count() != 0)
            {
                <table id="datatable" class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th class="col-md-3">Name</th>
                            <th class="col-md-3">Description</th>
                            <th class="col-md-3">Total/Count</th>
                            <th class="col-md-3">Price</th>
                            <th class="col-md-3">Last Customer Sold To</th>
                            <th class="col-md-3">Barcode</th>
                            <th class="col-md-3">Received Date</th>
                            <th class="col-md-3">Expiration Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                @if(item.ProductItems != null)
                                {
                                    @if(item.ProductItems.Count() != 0)
                                    {
                                    <td>@item.ProductItems.FirstOrDefault().Product.Name</td>
                                    <td>@item.ProductItems.FirstOrDefault().Product.Description</td>
                                    }
                                    else
                                    {
                                    <td></td>
                                    <td></td>                                        
                                    }
                                <td>@item.ProductItems.Count()</td>
                                }
                                else
                                {
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                }
                                <td>Last Customer Sold To</td>
                                <td>@item.Barcode</td>
                                <td>@item.ReceivedDate</td>
                                <td>@item.ExpirationDate></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            </div>
        </div>
    </div>
</div>