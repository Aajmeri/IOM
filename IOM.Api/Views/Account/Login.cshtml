@model IOM.Api.Models.LoginViewModel
@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Sign In";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="login-box">
  <div class="login-logo">
    <b>Royal</b> Distributors
  </div>
  <div class="card">
    <div class="card-body login-card-body">
      <p class="login-box-msg">Sign in to start your session</p>

      @if (!ViewData.ModelState.IsValid)
      {
        <div class="alert alert-danger alert-dismissible fade show">
          <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span>&times;</span></button>
          @foreach (var error in ViewData.ModelState.Values)
          {
            foreach (var msg in error.Errors)
            {
              <p class="mb-0">@msg.ErrorMessage</p>
            }
          }
        </div>
      }

      <form asp-action="Login" asp-route-returnUrl="@returnUrl" method="post">
        @Html.AntiForgeryToken()
        <div class="input-group mb-3">
          <input asp-for="Email" class="form-control" placeholder="Email" autofocus autocomplete="email">
          <div class="input-group-append">
            <div class="input-group-text"><span class="fas fa-envelope"></span></div>
          </div>
        </div>
        <span asp-validation-for="Email" class="text-danger small d-block mb-2"></span>

        <div class="input-group mb-3">
          <input asp-for="Password" class="form-control" placeholder="Password" autocomplete="current-password">
          <div class="input-group-append">
            <div class="input-group-text"><span class="fas fa-lock"></span></div>
          </div>
        </div>
        <span asp-validation-for="Password" class="text-danger small d-block mb-2"></span>

        <div class="row">
          <div class="col-8 d-flex align-items-center">
            <div class="icheck-primary">
              <input asp-for="RememberMe" id="remember">
              <label for="remember">Remember Me</label>
            </div>
          </div>
          <div class="col-4">
            <button type="submit" class="btn btn-primary btn-block">Sign In</button>
          </div>
        </div>
      </form>

      <p class="mt-3 mb-0 text-center">
        <a asp-controller="Account" asp-action="Register">Create an account</a>
      </p>
    </div>
  </div>
</div>
