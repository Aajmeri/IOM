@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Access Denied";
}

<div class="login-box">
  <div class="login-logo">
    <b>Royal</b> Distributors
  </div>
  <div class="card">
    <div class="card-body login-card-body text-center">
      <div class="mb-3">
        <i class="fas fa-ban fa-4x text-danger"></i>
      </div>
      <h4 class="login-box-msg">Access Denied</h4>
      <p class="text-muted">You do not have permission to view this page.</p>
      <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-block">
        <i class="fas fa-home mr-1"></i> Go to Dashboard
      </a>
    </div>
  </div>
</div>
